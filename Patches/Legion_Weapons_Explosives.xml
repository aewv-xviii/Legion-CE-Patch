<?xml version="1.0" encoding="utf-8" ?>
<Patch>
  <!-- Preserve Legion's original blast radii, but give HE ordnance explicit
       damage values so the large-area explosions do not feel too diluted. -->

  <Operation Class="PatchOperationConditional">
    <xpath>Defs/ThingDef[defName="Bullet_Shell_81mmHE"]/projectile/damageAmountBase</xpath>
    <nomatch Class="PatchOperationAdd">
      <xpath>Defs/ThingDef[defName="Bullet_Shell_81mmHE"]/projectile</xpath>
      <value>
        <damageAmountBase>55</damageAmountBase>
      </value>
    </nomatch>
    <match Class="PatchOperationReplace">
      <xpath>Defs/ThingDef[defName="Bullet_Shell_81mmHE"]/projectile/damageAmountBase</xpath>
      <value>
        <damageAmountBase>55</damageAmountBase>
      </value>
    </match>
  </Operation>

